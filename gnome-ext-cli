#!/usr/bin/env python3
import os
import sys
import json
import urllib.request
import urllib.parse
import subprocess
import argparse
import shutil
import tempfile
from pathlib import Path

STORE_JSON_URL = "https://raw.githubusercontent.com/extensions-gnome/store/main/extensions.json"
USER_EXT_DIR = Path.home() / ".local/share/gnome-shell/extensions"
SYSTEM_EXT_DIR = Path("/usr/share/gnome-shell/extensions")

# Colors for terminal
GREEN = "\033[92m"
YELLOW = "\033[93m"
RED = "\033[91m"
BLUE = "\033[94m"
BOLD = "\033[1m"
RESET = "\033[0m"

def log_info(msg):
    print(f"{BLUE}[INFO]{RESET} {msg}")

def log_success(msg):
    print(f"{GREEN}[SUCCESS]{RESET} {msg}")

def log_warn(msg):
    print(f"{YELLOW}[WARNING]{RESET} {msg}")

def log_error(msg):
    print(f"{RED}[ERROR]{RESET} {msg}", file=sys.stderr)

def send_notification(summary, body, urgency="normal"):
    try:
        subprocess.run(["notify-send", "-a", "GNOME Extension Store", "-u", urgency, summary, body], check=False)
    except Exception:
        pass
VERSION = "1.0.0"

def check_self_update():
    try:
        url = "https://raw.githubusercontent.com/extensions-gnome/cli/main/gnome-ext-cli"
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0 (GNOME Extension CLI)'})
        with urllib.request.urlopen(req, timeout=3) as response:
            content = response.read().decode('utf-8')
            
        import re
        match = re.search(r'VERSION\s*=\s*["\']([^"\']+)["\']', content)
        if match:
            remote_version = match.group(1)
            if remote_version != VERSION:
                log_warn(f"A new version of gnome-ext-cli is available: {remote_version} (current: {VERSION})")
                log_warn("To update the CLI tool, run: gnome-ext-cli self-update")
                return True
    except Exception:
        pass
    return False

def self_update():
    log_info("Checking for gnome-ext-cli updates...")
    try:
        url = "https://raw.githubusercontent.com/extensions-gnome/cli/main/gnome-ext-cli"
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0 (GNOME Extension CLI)'})
        with urllib.request.urlopen(req, timeout=10) as response:
            content = response.read().decode('utf-8')
            
        import re
        match = re.search(r'VERSION\s*=\s*["\']([^"\']+)["\']', content)
        if not match:
            log_error("Could not parse remote version from raw repository script.")
            return False
            
        remote_version = match.group(1)
        if remote_version == VERSION:
            log_success(f"gnome-ext-cli is already up-to-date (v{VERSION}).")
            return True
            
        log_info(f"Updating gnome-ext-cli from v{VERSION} to v{remote_version}...")
        
        current_script = Path(__file__).resolve()
        local_bin_script = Path.home() / ".local" / "bin" / "gnome-ext-cli"
        
        with tempfile.NamedTemporaryFile(mode='w', delete=False) as tmp:
            tmp.write(content)
            tmp_path = Path(tmp.name)
            
        try:
            if current_script.exists():
                shutil.copy2(tmp_path, current_script)
                current_script.chmod(0o755)
            if local_bin_script.exists() and local_bin_script != current_script:
                shutil.copy2(tmp_path, local_bin_script)
                local_bin_script.chmod(0o755)
                
            log_success(f"Successfully updated gnome-ext-cli to v{remote_version}!")
            return True
        finally:
            if tmp_path.exists():
                tmp_path.unlink()
    except Exception as e:
        log_error(f"Failed to update gnome-ext-cli: {e}")
        return False

def fetch_store_db():
    log_info("Fetching extensions database from store...")
    try:
        req = urllib.request.Request(
            STORE_JSON_URL, 
            headers={'User-Agent': 'Mozilla/5.0 (GNOME Extension CLI)'}
        )
        with urllib.request.urlopen(req, timeout=10) as response:
            return json.loads(response.read().decode('utf-8'))
    except Exception as e:
        log_error(f"Failed to fetch store database: {e}")
        sys.exit(1)

def get_installed_extensions():
    installed = {}
    
    # Check user-specific extensions
    if USER_EXT_DIR.exists():
        for item in USER_EXT_DIR.iterdir():
            if item.is_dir() and (item / "metadata.json").exists():
                uuid = item.name
                try:
                    with open(item / "metadata.json", "r") as f:
                        meta = json.load(f)
                    installed[uuid] = {
                        "path": item,
                        "version": meta.get("version", 0),
                        "name": meta.get("name", uuid),
                        "type": "user"
                    }
                except Exception:
                    pass
                    
    # Check system extensions
    if SYSTEM_EXT_DIR.exists():
        for item in SYSTEM_EXT_DIR.iterdir():
            if item.is_dir() and (item / "metadata.json").exists():
                uuid = item.name
                if uuid not in installed:  # User extensions override system ones
                    try:
                        with open(item / "metadata.json", "r") as f:
                            meta = json.load(f)
                        installed[uuid] = {
                            "path": item,
                            "version": meta.get("version", 0),
                            "name": meta.get("name", uuid),
                            "type": "system"
                        }
                    except Exception:
                        pass
    return installed

def install_extension(uuid, store_db=None, force=False):
    if not store_db:
        store_db = fetch_store_db()
        
    ext_data = next((x for x in store_db if x["uuid"] == uuid), None)
    if not ext_data:
        log_error(f"Extension '{uuid}' not found in the official store.")
        return False
        
    name = ext_data.get("name", uuid)
    zip_url = ext_data.get("zip_url")
    version = ext_data.get("version", "?")
    
    if not zip_url:
        log_error(f"Extension '{uuid}' does not have a ZIP download URL.")
        return False
        
    log_info(f"Downloading {BOLD}{name}{RESET} (v{version})...")
    
    try:
        # Create a temporary file for the ZIP
        with tempfile.NamedTemporaryFile(suffix=".zip", delete=False) as tmp_file:
            tmp_path = tmp_file.name
            
        req = urllib.request.Request(
            zip_url, 
            headers={'User-Agent': 'Mozilla/5.0 (GNOME Extension CLI)'}
        )
        with urllib.request.urlopen(req, timeout=15) as response, open(tmp_path, 'wb') as out_file:
            shutil.copyfileobj(response, out_file)
            
        log_info("Installing extension files...")
        # Use gnome-extensions to install the zip
        cmd = ["gnome-extensions", "install", "--force", tmp_path]
        res = subprocess.run(cmd, capture_output=True, text=True)
        
        # Clean up temp file
        try:
            os.unlink(tmp_path)
        except Exception:
            pass
            
        if res.returncode != 0:
            log_error(f"Failed to install extension {uuid}: {res.stderr.strip()}")
            return False
            
        # Enable extension
        log_info(f"Enabling extension {uuid}...")
        subprocess.run(["gnome-extensions", "enable", uuid], check=False)
        
        log_success(f"Successfully installed and enabled {BOLD}{name}{RESET}!")
        send_notification("Extension Installed", f"{name} (v{version}) has been installed and enabled. Re-log or restart Shell if needed.")
        return True
        
    except Exception as e:
        log_error(f"Error during installation of {uuid}: {e}")
        return False

def check_updates():
    check_self_update()
    installed = get_installed_extensions()
    if not installed:
        log_info("No GNOME extensions found installed on this system.")
        return {}
        
    store_db = fetch_store_db()
    updates = {}
    
    print(f"\n{BOLD}{'EXTENSION NAME':<35} {'UUID':<40} {'INSTALLED':<10} {'STORE':<10}{RESET}")
    print("-" * 100)
    
    for uuid, ext_info in installed.items():
        store_ext = next((x for x in store_db if x["uuid"] == uuid), None)
        if store_ext:
            local_ver = ext_info["version"]
            store_ver = store_ext.get("version", 0)
            
            # Convert versions to int for comparison if possible
            try:
                l_v = int(local_ver)
                s_v = int(store_ver)
            except ValueError:
                # Fallback to string comparison or simple parsing
                try:
                    # Strip any non-digit/dot characters
                    l_v_clean = ''.join(c for c in str(local_ver) if c.isdigit() or c == '.')
                    s_v_clean = ''.join(c for c in str(store_ver) if c.isdigit() or c == '.')
                    l_v = [int(x) for x in l_v_clean.split('.') if x.isdigit()]
                    s_v = [int(x) for x in s_v_clean.split('.') if x.isdigit()]
                except Exception:
                    l_v = str(local_ver)
                    s_v = str(store_ver)
                
            is_newer = False
            if isinstance(l_v, list) and isinstance(s_v, list):
                is_newer = s_v > l_v
            else:
                is_newer = s_v > l_v
                
            if is_newer:
                updates[uuid] = {
                    "name": ext_info["name"],
                    "local_version": local_ver,
                    "store_version": store_ver,
                    "zip_url": store_ext.get("zip_url")
                }
                status = f"{YELLOW}Update Available{RESET}"
                print(f"{ext_info['name']:<35} {uuid:<40} {str(local_ver):<10} {str(store_ver):<10} {status}")
            else:
                print(f"{ext_info['name']:<35} {uuid:<40} {str(local_ver):<10} {str(store_ver):<10} Up-to-date")
        else:
            # Extension not in this custom store
            pass
            
    print()
    if updates:
        log_success(f"Found {len(updates)} update(s) available.")
    else:
        log_info("All extensions are up-to-date.")
    return updates

def update_extensions(uuid=None, all_updates=False):
    updates = check_updates()
    if not updates:
        return
        
    store_db = fetch_store_db()
    
    if all_updates:
        log_info(f"Updating all {len(updates)} extensions...")
        success_count = 0
        for u in updates.keys():
            if install_extension(u, store_db=store_db):
                success_count += 1
        log_success(f"Updated {success_count}/{len(updates)} extensions successfully.")
    elif uuid:
        if uuid in updates:
            install_extension(uuid, store_db=store_db)
        else:
            log_warn(f"No updates available for extension '{uuid}' or it is not installed.")
    else:
        log_error("Please specify an extension UUID or run with --all to update all.")

def register_protocol():
    log_info("Registering gnome-ext:// custom URL scheme...")
    
    script_path = Path(__file__).resolve()
    
    # 1. Create wrapper in ~/.local/bin if not running from there
    local_bin = Path.home() / ".local" / "bin"
    local_bin.mkdir(parents=True, exist_ok=True)
    bin_target = local_bin / "gnome-ext-cli"
    
    try:
        shutil.copy2(script_path, bin_target)
        bin_target.chmod(0o755)
        log_info(f"Copied script to {bin_target}")
    except Exception as e:
        log_error(f"Failed to copy script to ~/.local/bin: {e}")
        log_info("Using current script path for desktop entry instead.")
        bin_target = script_path
        
    # 2. Write desktop file
    apps_dir = Path.home() / ".local" / "share" / "applications"
    apps_dir.mkdir(parents=True, exist_ok=True)
    desktop_file = apps_dir / "gnome-ext-handler.desktop"
    
    desktop_content = f"""[Desktop Entry]
Name=GNOME Extension Store Handler
Comment=Handles gnome-ext:// links to install extensions
Exec={bin_target} handle-url %u
Type=Application
MimeType=x-scheme-handler/gnome-ext;
NoDisplay=true
Terminal=false
Categories=Utility;
"""
    
    try:
        with open(desktop_file, "w") as f:
            f.write(desktop_content)
        desktop_file.chmod(0o755)
        log_info(f"Created desktop entry at {desktop_file}")
    except Exception as e:
        log_error(f"Failed to create desktop entry: {e}")
        sys.exit(1)
        
    # 3. Associate scheme using xdg-mime
    try:
        subprocess.run([
            "xdg-mime", "default", "gnome-ext-handler.desktop", "x-scheme-handler/gnome-ext"
        ], check=True)
        log_success("Registered gnome-ext scheme with xdg-mime!")
    except Exception as e:
        log_warn(f"Failed to register scheme with xdg-mime: {e}")
        
    # 4. Update desktop database
    try:
        subprocess.run(["update-desktop-database", str(apps_dir)], check=False)
    except Exception:
        pass
        
    log_success("URL Protocol handler registered successfully!")
    log_info("You can now install extensions directly by clicking links on the web interface.")

def setup_autoupdate():
    log_info("Configuring systemd auto-update service and timer...")
    
    local_bin = Path.home() / ".local" / "bin"
    bin_target = local_bin / "gnome-ext-cli"
    
    if not bin_target.exists():
        log_warn(f"CLI executable not found at {bin_target}. Registering CLI first...")
        register_protocol()
        
    systemd_user_dir = Path.home() / ".config" / "systemd" / "user"
    systemd_user_dir.mkdir(parents=True, exist_ok=True)
    
    service_file = systemd_user_dir / "gnome-ext-autoupdate.service"
    timer_file = systemd_user_dir / "gnome-ext-autoupdate.timer"
    
    service_content = f"""[Unit]
Description=GNOME Extension Store Auto-Updater
After=network-online.target

[Service]
Type=oneshot
ExecStart={bin_target} update --all
StandardOutput=journal
StandardError=journal
"""
    
    timer_content = """[Unit]
Description=Run GNOME Extension Store Auto-Updater periodically

[Timer]
OnCalendar=hourly
RandomizedDelaySec=600
Persistent=true

[Install]
WantedBy=timers.target
"""
    
    try:
        with open(service_file, "w") as f:
            f.write(service_content)
        with open(timer_file, "w") as f:
            f.write(timer_content)
            
        log_info("Reloading systemd user daemon...")
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
        
        log_info("Enabling and starting systemd timer...")
        subprocess.run(["systemctl", "--user", "enable", "--now", "gnome-ext-autoupdate.timer"], check=True)
        
        log_success("Auto-updates configured and scheduled (runs hourly)!")
    except Exception as e:
        log_error(f"Failed to setup systemd timer: {e}")
        sys.exit(1)

def run_gui_installer(uuid):
    import gi
    gtk_version = None
    try:
        gi.require_version('Gtk', '4.0')
        from gi.repository import Gtk, GLib
        gtk_version = 4
    except Exception:
        try:
            gi.require_version('Gtk', '3.0')
            from gi.repository import Gtk, GLib
            gtk_version = 3
        except Exception as e:
            raise RuntimeError(f"Could not load Gtk (GTK3/GTK4): {e}")
        
    import threading
    import queue
    
    class InstallWindow:
        def __init__(self):
            self.uuid = uuid
            self.log_queue = queue.Queue()
            
            if gtk_version == 4:
                self.app = Gtk.Application(application_id="es.inled.GnomeExtInstaller")
                self.app.connect('activate', self.on_activate)
            else:
                self.window = Gtk.Window()
                self.setup_ui()
                
        def on_activate(self, app):
            self.window = Gtk.ApplicationWindow(application=app)
            self.setup_ui()
            self.window.present()
            
        def setup_ui(self):
            self.window.set_title(f"Installing {self.uuid}")
            self.window.set_default_size(500, 350)
            
            main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
            if gtk_version == 4:
                main_box.set_margin_start(15)
                main_box.set_margin_end(15)
                main_box.set_margin_top(15)
                main_box.set_margin_bottom(15)
                self.window.set_child(main_box)
            else:
                main_box.set_border_width(15)
                self.window.add(main_box)
                
            self.status_label = Gtk.Label()
            self.status_label.set_halign(Gtk.Align.START)
            self.status_label.set_markup(f"<b>Installing Extension:</b> {self.uuid}")
            if gtk_version == 4:
                main_box.append(self.status_label)
            else:
                main_box.pack_start(self.status_label, False, False, 0)
                
            spinner_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            spinner_box.set_halign(Gtk.Align.CENTER)
            self.spinner = Gtk.Spinner()
            self.spinner.start()
            
            if gtk_version == 4:
                spinner_box.append(self.spinner)
            else:
                spinner_box.pack_start(self.spinner, False, False, 0)
                
            self.spinner_label = Gtk.Label(label="Downloading files...")
            if gtk_version == 4:
                spinner_box.append(self.spinner_label)
                main_box.append(spinner_box)
            else:
                spinner_box.pack_start(self.spinner_label, False, False, 0)
                main_box.pack_start(spinner_box, False, False, 0)
                
            scroll = Gtk.ScrolledWindow()
            scroll.set_vexpand(True)
            scroll.set_hexpand(True)
            
            self.text_view = Gtk.TextView()
            self.text_view.set_editable(False)
            self.text_view.set_cursor_visible(False)
            self.text_view.set_wrap_mode(Gtk.WrapMode.WORD)
            self.text_view.set_monospace(True)
            
            if gtk_version == 4:
                scroll.set_child(self.text_view)
                main_box.append(scroll)
            else:
                scroll.add(self.text_view)
                main_box.pack_start(scroll, True, True, 0)
                
            self.close_button = Gtk.Button(label="Close")
            self.close_button.set_halign(Gtk.Align.END)
            self.close_button.connect('clicked', lambda btn: self.window.close() if gtk_version == 4 else Gtk.main_quit())
            self.close_button.set_sensitive(False)
            
            if gtk_version == 4:
                main_box.append(self.close_button)
            else:
                main_box.pack_start(self.close_button, False, False, 0)
                self.window.connect('destroy', Gtk.main_quit)
                self.window.show_all()
                
            GLib.timeout_add(100, self.check_log_queue)
            
            self.install_thread = threading.Thread(target=self.run_install)
            self.install_thread.start()
            
        def check_log_queue(self):
            try:
                while True:
                    msg_type, msg = self.log_queue.get_nowait()
                    
                    buffer = self.text_view.get_buffer()
                    end_iter = buffer.get_end_iter()
                    # Strip color ANSI codes for clean textview display
                    clean_msg = msg.replace("\033[92m", "").replace("\033[93m", "").replace("\033[91m", "").replace("\033[94m", "").replace("\033[1m", "").replace("\033[0m", "")
                    buffer.insert(end_iter, clean_msg + "\n")
                    
                    mark = buffer.get_insert()
                    self.text_view.scroll_to_mark(mark, 0.0, True, 0.5, 1.0)
                    
                    if msg_type == "SUCCESS":
                        self.spinner.stop()
                        self.spinner_label.set_markup("<span foreground='green'><b>Success!</b> Extension installed and enabled.</span>")
                        self.status_label.set_markup(f"<b>Installation Complete:</b> {self.uuid}")
                        
                        GLib.timeout_add_seconds(2, self.auto_close)
                    elif msg_type == "ERROR":
                        self.spinner.stop()
                        self.spinner_label.set_markup("<span foreground='red'><b>Failed!</b> See logs below.</span>")
                        self.close_button.set_sensitive(True)
            except queue.Empty:
                pass
            return True
            
        def auto_close(self):
            if gtk_version == 4:
                self.window.close()
            else:
                Gtk.main_quit()
            return False
            
        def run_install(self):
            def log_to_queue(msg_type, text):
                self.log_queue.put((msg_type, text))
                
            original_info = globals()['log_info']
            original_success = globals()['log_success']
            original_warn = globals()['log_warn']
            original_error = globals()['log_error']
            
            globals()['log_info'] = lambda msg: log_to_queue("INFO", f"[INFO] {msg}")
            globals()['log_success'] = lambda msg: log_to_queue("SUCCESS", f"[SUCCESS] {msg}")
            globals()['log_warn'] = lambda msg: log_to_queue("WARN", f"[WARNING] {msg}")
            globals()['log_error'] = lambda msg: log_to_queue("ERROR", f"[ERROR] {msg}")
            
            try:
                success = install_extension(self.uuid)
                if not success:
                    log_to_queue("ERROR", "Installation failed.")
            except Exception as e:
                log_to_queue("ERROR", f"Exception occurred: {e}")
            finally:
                globals()['log_info'] = original_info
                globals()['log_success'] = original_success
                globals()['log_warn'] = original_warn
                globals()['log_error'] = original_error
                
        def run(self):
            if gtk_version == 4:
                self.app.run([])
            else:
                Gtk.main()
                
    win = InstallWindow()
    win.run()

def handle_url(url):
    log_info(f"Handling URL request: {url}")
    parsed = urllib.parse.urlparse(url)
    
    if parsed.scheme != "gnome-ext":
        log_error(f"Invalid scheme: {parsed.scheme}")
        sys.exit(1)
        
    action = parsed.netloc or parsed.path.split('/')[0]
    
    if action == "install":
        uuid = None
        queries = urllib.parse.parse_qs(parsed.query)
        if "uuid" in queries:
            uuid = queries["uuid"][0]
            
        if not uuid:
            path_parts = parsed.path.strip('/').split('/')
            if len(path_parts) > 0 and path_parts[0]:
                uuid = path_parts[0]
                
        if not uuid:
            log_error("No UUID provided in URL.")
            send_notification("Installation Error", "No UUID specified in the installation link.", urgency="critical")
            sys.exit(1)
            
        log_info(f"URL request received to install extension: {uuid}")
        
        gui_available = False
        if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
            try:
                import gi
                gi.require_version('Gtk', '4.0')
                gui_available = True
            except Exception:
                try:
                    import gi
                    gi.require_version('Gtk', '3.0')
                    gui_available = True
                except Exception:
                    pass
                    
        if gui_available:
            try:
                run_gui_installer(uuid)
                sys.exit(0)
            except Exception as e:
                log_warn(f"Failed to start GUI installer: {e}. Falling back to CLI installation.")
                
        send_notification("Installing Extension", f"Downloading and installing {uuid}...")
        if install_extension(uuid):
            sys.exit(0)
        else:
            send_notification("Installation Failed", f"Could not install extension {uuid}.", urgency="critical")
            sys.exit(1)
    else:
        log_error(f"Unknown action: {action}")
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="GNOME Extension Store CLI Helper")
    subparsers = parser.add_subparsers(dest="command", help="Command to run")
    
    # Install
    inst_parser = subparsers.add_parser("install", help="Install an extension from the store")
    inst_parser.add_argument("uuid", help="UUID of the extension to install")
    
    # Check updates
    subparsers.add_parser("check-updates", help="Check for available updates in the store")
    
    # Update
    up_parser = subparsers.add_parser("update", help="Update extensions")
    up_parser.add_argument("uuid", nargs="?", help="UUID of the extension to update")
    up_parser.add_argument("--all", action="store_true", help="Update all extensions with updates")
    
    # Register protocol
    subparsers.add_parser("register", help="Register gnome-ext:// URL protocol handler")
    
    # Setup autoupdate
    subparsers.add_parser("setup-autoupdate", help="Setup systemd automatic updates (hourly)")
    
    # Handle URL
    url_parser = subparsers.add_parser("handle-url", help="Internal use to handle gnome-ext:// URLs")
    url_parser.add_argument("url", help="The URL to handle")
    
    # Self update
    subparsers.add_parser("self-update", help="Update the gnome-ext-cli tool itself to the latest version")
    
    args = parser.parse_args()
    
    if args.command == "install":
        install_extension(args.uuid)
    elif args.command == "check-updates":
        check_updates()
    elif args.command == "update":
        update_extensions(args.uuid, args.all)
    elif args.command == "register":
        register_protocol()
    elif args.command == "setup-autoupdate":
        setup_autoupdate()
    elif args.command == "handle-url":
        handle_url(args.url)
    elif args.command == "self-update":
        self_update()
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
